{
    "name": "mapsight/pulp-xml",
    "description": "Handlers for parsing and manipulating XML data.",
    "type": "library",
    "keywords": [
        "mapsight",
        "pulp",
        "xml",
        "parsing"
    ],
    "homepage": "https://github.com/open-mapsight/mapsight-pulp",
    "license": "MIT",
    "authors": [
        {
            "name": "Paul Golmann",
            "email": "mail@pje-web.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/open-mapsight/mapsight-pulp/issues",
        "source": "https://github.com/open-mapsight/mapsight-pulp/tree/main/packages/pulp-xml"
    },
    "require": {
        "php": "^8.2",
        "symfony/polyfill-php83": "^1.37",
        "symfony/polyfill-php84": "^1.37",
        "symfony/polyfill-php85": "^1.37",
        "ext-libxml": "*",
        "ext-simplexml": "*",
        "mapsight/pulp": "*"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "OpenMapsight\\pulpxml\\": "src"
        },
        "classmap": [
            "PulpXML.php"
        ]
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    },
    "archive": {
        "exclude": [
            "*",
            ".*",
            "!/src/*",
            "!/PulpXML.php"
        ]
    }
}
